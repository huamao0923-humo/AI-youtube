.env
__pycache__/
*.pyc
*.pyo
.venv/
venv/
env/

# SQLite WAL / 暫存
data/channel.db
data/channel.db-journal
data/channel.db-shm
data/channel.db-wal

# 每日暫存資料（不入版本庫）
data/briefs/
data/scoring_queue.json
data/scored_results.json
data/social/
data/reports/

# 爬蟲快取 / 產物
data/news_cache/*
!data/news_cache/.gitkeep
data/scripts/*
!data/scripts/.gitkeep
data/audio/*
!data/audio/.gitkeep
data/images/*
!data/images/.gitkeep
data/videos/*
!data/videos/.gitkeep

# 日誌
logs/*
!logs/.gitkeep

# 聲音樣本（個人隱私）
voice_samples/raw/*
voice_samples/processed/*
!voice_samples/.gitkeep

# YouTube 認證（機密）
config/youtube_client_secret.json
config/youtube_token.json

# IDE / 系統
.vscode/
.idea/
.DS_Store
Thumbs.db
