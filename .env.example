# ==============================================================
# AI 頻道自動化系統 — 環境變數範本
# 複製此檔案為 .env 後填入真實值
# ==============================================================

# ── Web UI 登入 ──────────────────────────────────────────────
# 登入 Web UI 的密碼（Railway + 本地都需要）
WEB_PASSWORD=your-password-here

# Flask session 加密金鑰（隨意輸入一段長字串）
SECRET_KEY=ai-channel-secret-key-change-this

# ── 資料庫 ───────────────────────────────────────────────────
# 本地 SQLite（預設，不需設定）
# DATABASE_URL=

# Railway + Neon PostgreSQL（部署時填入 Neon 連線字串）
# DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/dbname?sslmode=require

# ── Claude API ───────────────────────────────────────────────
# 用於腳本生成、深度研究、新聞評分
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# ── YouTube API ──────────────────────────────────────────────
# client_secret.json 放置路徑（相對於專案根目錄）
YOUTUBE_CLIENT_SECRET_PATH=./config/youtube_client_secret.json

# ── ComfyUI 影像生成 ─────────────────────────────────────────
# 本地 ComfyUI 服務位址（未啟動時自動使用佔位圖）
COMFYUI_HOST=http://localhost:8188

# ── Pexels B-roll 素材（強烈建議）────────────────────────────
# 免費 API Key 申請：https://www.pexels.com/api/
# 設定後影片會大量使用真實影像片段（商業本質風格）
# 空值或未設 → 自動退回 AI 生圖
PEXELS_API_KEY=

# ── TTS 配音 ─────────────────────────────────────────────────
# 優先序：Google TTS → XTTS-v2 → edge-tts → 靜音

# Google Cloud TTS（真正台灣口音，最高優先）
# 申請：console.cloud.google.com → 啟用 Text-to-Speech API → 建立 API 金鑰
# 免費額度：WaveNet 每月 100 萬字元（日更頻道約 50-70 集）
GOOGLE_TTS_API_KEY=
# 聲音選項：
#   cmn-TW-Wavenet-C（男，年輕有活力，推薦科技題）★ 預設
#   cmn-TW-Wavenet-B（男，沉穩，推薦新聞播報）
#   cmn-TW-Wavenet-A（女，清亮）
GOOGLE_TTS_VOICE=

# edge-tts 聲音覆寫（Google 未設定時使用，免費無需 Key）
# 常用：zh-TW-YunJheNeural（男）/ zh-TW-HsiaoChenNeural（女）
#       zh-CN-YunxiNeural（男，情緒起伏大）/ zh-CN-YunjianNeural（男，播報風）
EDGE_TTS_VOICE=

# ── 選用：Telegram 推送 ──────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
