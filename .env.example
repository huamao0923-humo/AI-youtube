# ==============================================================
# AI 頻道自動化系統 — 環境變數範本
# 複製此檔案為 .env 後填入真實值
# ==============================================================

# ── Web UI 登入 ──────────────────────────────────────────────
# 登入 Web UI 的密碼（Railway + 本地都需要）
WEB_PASSWORD=your-password-here

# Flask session 加密金鑰（隨意輸入一段長字串）
SECRET_KEY=ai-channel-secret-key-change-this

# ── 資料庫 ───────────────────────────────────────────────────
# 本地 SQLite（預設，不需設定）
# DATABASE_URL=

# Railway + Neon PostgreSQL（部署時填入 Neon 連線字串）
# DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/dbname?sslmode=require

# ── Claude API ───────────────────────────────────────────────
# 用於腳本生成、深度研究、新聞評分
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# ── YouTube API ──────────────────────────────────────────────
# client_secret.json 放置路徑（相對於專案根目錄）
YOUTUBE_CLIENT_SECRET_PATH=./config/youtube_client_secret.json

# ── ComfyUI 影像生成 ─────────────────────────────────────────
# 本地 ComfyUI 服務位址（未啟動時自動使用佔位圖）
COMFYUI_HOST=http://localhost:8188

# ── TTS 配音 ─────────────────────────────────────────────────
# edge-tts 不需要 API Key，自動使用 zh-TW-YunJheNeural
# 若日後要換女聲，在 modules/tts/xtts_engine.py 改 EDGE_TTS_VOICE

# ── 選用：Telegram 推送 ──────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
